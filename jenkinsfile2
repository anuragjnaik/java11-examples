pipeline {
    agent any

    stages {

        stage('Clone Repository') {
            steps {
                git 'https://github.com/anuragjnaik/java11-examples.git'
            }
        }

        stage('build') {
            steps {
                sh 'docker build -t anuragjnaik/java11-examples:latest -f Dockerfile .'
            }
        }
    }
}
