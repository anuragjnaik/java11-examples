pipeline {
    agent any

    stages {

        stage('Clone Repository') {
            steps {
                git 'https://github.com/anuragjnaik/java11-examples.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t anuragjnaik/java11-examples:latest -f Dockerfile .'
            }
        }

        stage('Push') {
            steps {
              withCredentials([usernamePassword(credentialsId: 'dockerlogin', passwordVariable: 'password', usernameVariable: 'username')]) {
    

                sh '''
                echo $password | docker login -u $username --password-stdin

                docker push anuragjnaik/java11-examples:latest
                '''
            }
        }
}
        stage('Install Trivy') {
            steps {
                sh '''
                sudo apt-get install wget gnupg -y

                wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | \
                gpg --dearmor | \
                sudo tee /usr/share/keyrings/trivy.gpg > /dev/null

                echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" | \
                sudo tee -a /etc/apt/sources.list.d/trivy.list

                sudo apt-get update

                sudo apt-get install trivy -y
                '''
            }
        }

        stage('Trivy Scan') {
            steps {
                sh 'trivy image anuragjnaik/java11-examples:latest'
            }
        }
          stage('mailing') {
            steps {
    mail bcc: '', body: 'i have sent the build and output of trivy scan', cc: '', from: 'naikanurag6003@gmail.com', replyTo: '', subject: 'trivy ', to: 'jn.anurag497@gmail.com'
    }
}
 }
}
