pipeline {
    agent any

    stages {

        stage('Clone Repository') {
            steps {
                git 'https://github.com/anuragjnaik/java11-examples.git'
            }
        }

        stage('build') {
            steps {
                sh 'docker build -t anuragjnaik/java11-examples:latest -f Dockerfile .'
            }
        }

         stage('push') {
            steps {
                sh '''echo \'testokayyyyy' | docker login -u anuragjnaik --password-stdin
docker push anuragjnaik/java11-examples:latest'''
            }
        }
    }
}
