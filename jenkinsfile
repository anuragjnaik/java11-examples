pipeline {
    agent any

    stages {

        stage('Install Maven') {
            steps {
                sh '''
                sudo apt-get update
                sudo apt-get install maven -y
                '''
            }
        }

        stage('Install JDK') {
            steps {
                sh '''
                sudo apt-get install openjdk-21-jdk -y
                '''
            }
        }

        stage('Clone Repository') {
            steps {
                git 'https://github.com/anuragjnaik/java11-examples.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean install'
            }
        }
    }
}
